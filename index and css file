css file
/* Reset some default styles */
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f3f3f3;
    color: #333;
}

/* Navigation */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #004466;
    color: white;
    padding: 15px 20px;
}

.nav-links {
    list-style: none;
    display: flex;
    gap: 20px;
}

.nav-links a {
    color: white;
    text-decoration: none;
    font-weight: bold;
}

.nav-links a:hover {
    text-decoration: underline;
}

/* Container section */
.container {
    background: #fff3cd;
    border: 2px solid #e0a800;
    margin: 20px;
    padding: 20px;
    border-radius: 8px;
}

/* Headings & Paragraphs */
h1, h2, h3 {
    margin-bottom: 10px;
}

p {
    line-height: 1.6;
}

/* Card Section */
.card-section {
    display: flex;
    gap: 20px;
    margin: 20px;
}

.card {
    background: #e6f7ff;
    border: 2px solid #0099cc;
    border-radius: 10px;
    padding: 20px;
    flex: 1;
    text-align: center;
}

.card h3 {
    margin-top: 0;
}

/* Buttons */
button {
    background: #0099cc;
    color: white;
    padding: 10px 15px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    margin-top: 10px;
}

button:hover {
    background: #007799;
}

/* Footer */
footer {
    background: #004466;
    color: white;
    text-align: center;
    padding: 15px;
    margin-top: 20px;
}
